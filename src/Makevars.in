CXX_STD = CXX17
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) @GDAL_CFLAGS@
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) @GDAL_LIBS@

# Set HAVE_GDAL_PIXFUN flag if GDAL >= 3.4 is available
HAVE_GDAL_PIXFUN = @HAVE_GDAL_PIXFUN@
ifeq ($(HAVE_GDAL_PIXFUN),yes)
PKG_CXXFLAGS += -DHAVE_GDAL_PIXFUN
endif
