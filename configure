#!/bin/sh
# configure script for vrtility
# Finds GDAL headers and libraries needed for C++ pixel function registration

# Find R
: ${R_HOME=`R RHOME`}
if test -z "${R_HOME}"; then
  echo "could not determine R_HOME"
  exit 1
fi

# Try gdal-config first
GDAL_CONFIG=$(command -v gdal-config 2>/dev/null)

if test -n "${GDAL_CONFIG}"; then
  GDAL_CFLAGS=$("${GDAL_CONFIG}" --cflags)
  GDAL_LIBS=$("${GDAL_CONFIG}" --libs)
  GDAL_VERSION=$("${GDAL_CONFIG}" --version)
  echo "Found GDAL ${GDAL_VERSION} via gdal-config"
else
  # Try pkg-config
  PKG_CONFIG=$(command -v pkg-config 2>/dev/null)
  if test -n "${PKG_CONFIG}" && "${PKG_CONFIG}" --exists gdal 2>/dev/null; then
    GDAL_CFLAGS=$("${PKG_CONFIG}" --cflags gdal)
    GDAL_LIBS=$("${PKG_CONFIG}" --libs gdal)
    GDAL_VERSION=$("${PKG_CONFIG}" --modversion gdal)
    echo "Found GDAL ${GDAL_VERSION} via pkg-config"
  else
    echo "-------------------------------------------------------"
    echo "GDAL not found via gdal-config or pkg-config."
    echo "C++ pixel functions will not be available."
    echo "Python/muparser pixel functions will be used as fallback."
    echo "-------------------------------------------------------"
    GDAL_CFLAGS=""
    GDAL_LIBS=""
    GDAL_VERSION=""
  fi
fi

# Check for GDAL >= 3.4 (needed for GDALAddDerivedBandPixelFuncWithArgs)
HAVE_GDAL_PIXFUN="no"
if test -n "${GDAL_VERSION}"; then
  GDAL_MAJOR=$(echo "${GDAL_VERSION}" | cut -d. -f1)
  GDAL_MINOR=$(echo "${GDAL_VERSION}" | cut -d. -f2)
  if test "${GDAL_MAJOR}" -gt 3 2>/dev/null || \
     (test "${GDAL_MAJOR}" -eq 3 && test "${GDAL_MINOR}" -ge 4 2>/dev/null); then
    HAVE_GDAL_PIXFUN="yes"
    echo "GDAL >= 3.4 detected: C++ pixel functions enabled"
  else
    echo "GDAL < 3.4: C++ pixel functions disabled (need >= 3.4)"
    GDAL_CFLAGS=""
    GDAL_LIBS=""
  fi
fi

# Write Makevars
sed \
  -e "s|@GDAL_CFLAGS@|${GDAL_CFLAGS}|" \
  -e "s|@GDAL_LIBS@|${GDAL_LIBS}|" \
  -e "s|@HAVE_GDAL_PIXFUN@|${HAVE_GDAL_PIXFUN}|" \
  src/Makevars.in > src/Makevars

echo "Configuration complete."
